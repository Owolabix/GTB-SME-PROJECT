# Supabase (same project for Lynk UI + CX-Assistant)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_anon_key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key
VITE_SUPABASE_PROJECT_ID=your_project_id
# Required for server-side account deletion (GDPR / NDPR erasure) and webhooks
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Meta / Instagram — server only except VITE_* for OAuth redirect in browser
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://localhost:8080/integrations
META_WEBHOOK_VERIFY_TOKEN=change-me
VITE_META_APP_ID=
VITE_META_REDIRECT_URI=https://localhost:8080/integrations

# Optional: public Lynk API (ngrok tunnel to npm run dev). Restart dev after changes.
VITE_API_BASE_URL=https://your-subdomain.ngrok-free.app

# Optional: link in Settings → Product catalogue ("Manage products in AISLE")
VITE_STOREFRONT_ADMIN_URL=https://aisle-sandy.vercel.app/admin/login

# AISLE storefront catalogue (server only — used by /api/storefront/catalogue + CX-Assistant)
AISLE_STOREFRONT_API_URL=https://aisle-sandy.vercel.app/api/storefront/products
AISLE_API_KEY=your_aisle_chatbot_api_key

# Optional — omit on Vercel if you are not running CX-Assistant yet
# CX_ASSISTANT_URL=http://localhost:3000
# CX_ASSISTANT_INTERNAL_SECRET=change-me-to-a-long-random-string

# GTCO SME signup gate (server only — set on Vercel for production)
# GTCO_SIGNUP_ACCESS_CODE=your-relationship-manager-code
# GTCO_ALLOWED_EMAIL_DOMAINS=gtbank.com,yourbusiness.com
